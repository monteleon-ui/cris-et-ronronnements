{
  "name": "cris-et-ronronnements",
  "version": "1.0.0",
  "description": "Site web dédié à l'exploration de soi et des autres à travers des questionnaires, des ressources et des œuvres littéraires.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"nodemon app.js\" \"npm run watch:css\" \"npm run watch:js\"",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss public/assets/css/style.css --output public/assets/css/style.min.css --env production",
    "build:js": "terser public/assets/js/config.js --compress --mangle --output public/assets/js/config.min.js",
    "build:all": "npm run clean && npm run build",
    "watch:css": "postcss public/assets/css/style.css --output public/assets/css/style.min.css --watch",
    "watch:js": "terser public/assets/js/config.js --compress --mangle --output public/assets/js/config.min.js --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test:accessibility": "echo 'Running accessibility tests...' && npm run build",
    "clean": "rm -rf public/assets/css/style.min.css public/assets/js/config.min.js",
    "predeploy": "npm run clean && npm run build:all",
    "validate": "npm run lint && npm run build"
  },
  "dependencies": {
    "bootstrap": "^5.3.2",
    "compression": "^1.7.4",
    "dotenv-safe": "^8.2.0",
    "ejs": "^3.1.10",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "cssnano": "^7.0.5",
    "eslint": "^9.15.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.3.3",
    "terser": "^5.34.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "BDSM",
    "Fetish",
    "Kink",
    "BFK",
    "IUFMM",
    "Simon Vitsonnet",
    "poésie",
    "littérature"
  ],
  "author": "Simon Vitsonnet",
  "license": "MIT"
}

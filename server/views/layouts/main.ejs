<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Site dédié à l'exploration de soi et des autres à travers des questionnaires, des ressources et des œuvres littéraires.">
    <title><%= title || 'Cris et Ronronnements' %></title>
    <link rel="canonical" href="https://cris-et-ronronnements.net">

    <!-- Microdonnées globales (Organization + WebSite) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Cris et Ronronnements",
      "url": "https://cris-et-ronronnements.net",
      "logo": "https://cris-et-ronronnements.net/assets/images/favicon.ico",
      "description": "Site dédié à l'exploration de soi et des autres à travers des questionnaires, des ressources et des œuvres littéraires.",
      "hasPart": {
        "@type": "WebSite",
        "name": "Cris et Ronronnements",
        "url": "https://cris-et-ronronnements.net",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://cris-et-ronronnements.net/?s={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    }
    </script>

    <!-- Favicon avec aria-label -->
    <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon" aria-label="Favicon de Cris et Ronronnements">
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" aria-label="Icône Apple Touch pour Cris et Ronronnements">
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="/assets/Bootstrap/css/bootstrap.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/assets/css/style.css">
    
    <!-- Redirection pour les visiteurs sans JavaScript -->
    <noscript>
        <meta http-equiv="refresh" content="0; url=https://simonvitsonnet.com/cris-et-ronronnemets.html">
    </noscript>
</head>
<body>
    <!-- En-tête avec rôle ARIA -->
    <header role="banner">
        <%- include('../partials/header') %>
    </header>
    
    <!-- Contenu principal avec rôle ARIA -->
    <main role="main">
        <%- body || '' %>
    </main>
    
    <!-- Pied de page avec rôle ARIA -->
    <footer role="contentinfo">
        <%- include('../partials/footer') %>
    </footer>
    
    <!-- Bootstrap JS Bundle (includes Popper) -->
    <script src="/assets/Bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>

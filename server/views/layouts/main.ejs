<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= metaDescription || 'Site dédié à l\'exploration de soi et des autres à travers des questionnaires, des ressources et des œuvres littéraires.' %>">
    <meta name="keywords" content="<%= metaKeywords || 'BDSM, Fetish, Kink, BFK, IUFMM, Simon Vitsonnet, poésie, littérature, formation, questionnaire' %>">
    <meta name="author" content="Simon Vitsonnet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cris-et-ronronnements.net<%= canonicalUrl || '' %>">
    <meta property="og:title" content="<%= title || 'Cris et Ronronnements' %>">
    <meta property="og:description" content="<%= metaDescription || 'Un espace dédié à l\'exploration de soi et des autres, à travers des questionnaires, des ressources et des œuvres littéraires.' %>">
    <meta property="og:image" content="https://cris-et-ronronnements.net/assets/images/favicon.ico">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= title || 'Cris et Ronronnements' %>">
    <meta name="twitter:description" content="<%= metaDescription || 'Un espace dédié à l\'exploration de soi et des autres, à travers des questionnaires, des ressources et des œuvres littéraires.' %>">
    <meta name="twitter:image" content="https://cris-et-ronronnements.net/assets/images/favicon.ico">
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://cris-et-ronronnements.net<%= canonicalUrl || '' %>">
    
    <!-- Favicon -->
    <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon" loading="lazy">
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" loading="lazy">
    
    <!-- Preload pour les ressources critiques -->
    <link rel="preload" href="/assets/bootstrap/css/bootstrap.min.css" as="style">
    <link rel="preload" href="/assets/css/style.min.css" as="style">
    <link rel="preload" href="/assets/bootstrap/js/bootstrap.bundle.min.js" as="script">
    <link rel="preload" href="/assets/js/config.min.js" as="script">
    
    <!-- Bootstrap 5 local (minifié) -->
    <link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    
    <!-- Custom CSS (minifié en production) -->
    <link rel="stylesheet" href="/assets/css/style.min.css">
    
    <!-- Microdonnées globales (Organization + WebSite) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Cris et Ronronnements",
      "url": "https://cris-et-ronronnements.net",
      "logo": "https://cris-et-ronronnements.net/assets/images/favicon.ico",
      "description": "Site dédié à l'exploration de soi et des autres à travers des questionnaires, des ressources et des œuvres littéraires.",
      "hasPart": {
        "@type": "WebSite",
        "name": "Cris et Ronronnements",
        "url": "https://cris-et-ronronnements.net",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://cris-et-ronronnements.net/?s={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    }
    </script>
    
    <!-- Message pour les visiteurs sans JavaScript -->
    <noscript>
        <style>
            .noscript-message {
                padding: 20px;
                background-color: #fff3cd;
                border: 1px solid #ffc107;
                color: #856404;
                text-align: center;
                margin: 0;
            }
        </style>
        <div class="noscript-message" role="alert">
            <p><strong>JavaScript est désactivé sur votre navigateur.</strong></p>
            <p>Certaines fonctionnalités du site peuvent ne pas fonctionner correctement.</p>
            <p>Pour une expérience optimale, veuillez activer JavaScript ou consulter 
            <a href="https://simonvitsonnet.com/cris-et-ronronnemets.html" aria-label="Version alternative du site (s'ouvre dans une nouvelle fenêtre)">la version alternative du site</a>.</p>
        </div>
    </noscript>
</head>
<body>
    <!-- Skip to main content pour l'accessibilité -->
    <a href="#main-content" class="visually-hidden-focusable" style="position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;">
        Aller au contenu principal
    </a>
    
    <!-- En-tête avec rôle ARIA -->
    <header role="banner">
        <%- include('../partials/header') %>
    </header>
    
    <!-- Contenu principal avec rôle ARIA -->
    <main id="main-content" role="main">
        <%- body || '' %>
    </main>
    
    <!-- Pied de page avec rôle ARIA -->
    <footer role="contentinfo">
        <%- include('../partials/footer') %>
    </footer>
    
    <!-- Bootstrap 5 JS Bundle local (minifié, inclut Popper) -->
    <script src="/assets/bootstrap/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    
    <!-- Custom JS (minifié en production) -->
    <script src="/assets/js/config.min.js"></script>
</body>
</html>

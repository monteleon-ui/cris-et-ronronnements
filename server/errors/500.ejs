<!-- Error Page: 500.ejs -->
<%- include('../layouts/main', { 
    title: '500 - Erreur serveur',
    body: function() { %>

<div class="container text-center my-5">
    <div class="error-container">
        <h1 class="display-1 fw-bold text-danger">500</h1>
        <h2 class="mb-4">Erreur serveur</h2>
        <p class="lead mb-5">
            Désolé, une erreur interne est survenue. Notre équipe a été notifiée.
        </p>
        
        <div class="d-grid gap-2 d-md-block justify-content-md-center">
            <a href="/" class="btn btn-primary btn-lg me-md-3">
                <i class="bi bi-house me-2"></i> Retour à l'accueil
            </a>
            <button onclick="location.reload()" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-clockwise me-2"></i> Réessayer
            </button>
        </div>
        
        <div class="mt-5">
            <div class="spinner-border text-danger" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    </div>
</div>

<style>
    .error-container {
        max-width: 600px;
        margin: 0 auto;
    }
    .display-1 {
        font-size: 8rem;
        line-height: 1;
    }
</style>

<% } %>

<!-- Error Page: 404.ejs -->
<%- include('../layouts/main', { 
    title: '404 - Page non trouvée',
    body: function() { %>

<div class="container text-center my-5">
    <div class="error-container">
        <h1 class="display-1 fw-bold text-primary">404</h1>
        <h2 class="mb-4">Page non trouvée</h2>
        <p class="lead mb-5">
            Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        </p>
        
        <div class="d-grid gap-2 d-md-block justify-content-md-center">
            <a href="/" class="btn btn-primary btn-lg me-md-3">
                <i class="bi bi-house me-2"></i> Retour à l'accueil
            </a>
            <a href="/legal/contact" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-envelope me-2"></i> Nous contacter
            </a>
        </div>
        
        <div class="mt-5">
            <img src="/assets/images/404-illustration.svg" alt="Page non trouvée" class="img-fluid" style="max-height: 200px; opacity: 0.7;">
        </div>
    </div>
</div>

<style>
    .error-container {
        max-width: 600px;
        margin: 0 auto;
    }
    .display-1 {
        font-size: 8rem;
        line-height: 1;
    }
</style>

<% } %>
